{
  "name": "@alr/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bootstrap/server.ts",
    "dev:worker": "tsx watch src/bootstrap/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bootstrap/server.js",
    "start:worker": "node dist/bootstrap/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@alr/shared": "file:../../packages/shared",
    "@prisma/client": "^6.14.0",
    "bullmq": "^5.58.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.5.0",
    "ioredis": "^5.6.1",
    "nodemailer": "^6.10.1",
    "fastify-raw-body": "^5.0.0",
    "stripe": "^17.7.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.14.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
