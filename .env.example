NODE_ENV=development
PORT=4000
WEB_PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autonomous_leads?schema=public
REDIS_URL=redis://localhost:6379

APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost
API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=/api/v1
CORS_ORIGIN=http://localhost:3000
API_PROXY_TARGET=http://api:4000

AUTH_COOKIE_NAME=alr_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_DAYS=30
AUTH_PASSWORD_RESET_TTL_MINUTES=60
AUTH_OAUTH_STATE_TTL_MINUTES=10

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

LLM_PROVIDER=mock
LLM_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# Email delivery
# Local development defaults to Mailpit over SMTP. Open http://localhost:8025 to inspect messages.
# - smtp: real SMTP provider such as Gmail, Mailgun, Postmark, or SendGrid SMTP
# - webhook: POST messages to your own email relay endpoint
EMAIL_PROVIDER=smtp
EMAIL_WEBHOOK_URL=
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=lead-agent@example.com

WHATSAPP_PROVIDER=stub
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

CALENDAR_PROVIDER=local
CALENDAR_PUBLIC_URL=http://localhost:3000
CALENDAR_WEBHOOK_URL=
CALENDAR_TIMEZONE=Asia/Kolkata
BOOKING_SLOT_MINUTES=30
BOOKING_WINDOW_DAYS=14
WORKER_CONCURRENCY=10

AUTO_PROMOTION=true
DEFAULT_SEQUENCE_NAME=default-outreach
DEFAULT_TIMEZONE=Asia/Kolkata
ADMIN_API_KEYS=
ADMIN_API_KEY=

# Billing / SaaS
WORKSPACE_TRIAL_DAYS=14
CAPTURE_KEY_PREFIX=cap
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PORTAL_RETURN_URL=
